{
  "name": "gigazonk",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:itch": "vite build --base=./",
    "check:itch": "npm run lint && npm run typecheck && npm run test && npm run build:itch",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "lint": "eslint src tests e2e --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:e2e": "node scripts/run-playwright.mjs",
    "test:e2e:cross": "node scripts/run-e2e-cross.mjs",
    "test:e2e:ui": "node scripts/run-playwright.mjs --ui",
    "test:e2e:headed": "node scripts/run-playwright.mjs --headed",
    "collect-browser-errors": "node scripts/collect-browser-errors.mjs",
    "verify-browser-debug": "node scripts/verify-browser-debug.mjs",
    "setup:mcp": "node scripts/generate-cursor-mcp.mjs",
    "setup:extensions": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-vscode-extensions.ps1",
    "gsync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/gsync-to-drive.ps1 -Repo GigaZonk",
    "export-data": "node scripts/export-game-data.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "update:itch-description": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-itch-description.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@timjen/playwright-three": "^0.4.2",
    "@types/node": "^26.0.0",
    "@typescript-eslint/parser": "^8.64.0",
    "chrome-devtools-mcp": "^1.4.0",
    "eslint": "^10.5.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
    "vite-mcp": "^0.2.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
